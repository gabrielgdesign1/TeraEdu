# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Use a "publishable key" (sb_publishable_...), não a legacy JWT anon key (eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Rate limiting (Upstash Redis) — obrigatório em produção para o rate limit
# funcionar corretamente entre múltiplas instâncias da Vercel. Sem essas duas
# variáveis, o app cai automaticamente para um limitador em memória (só serve
# para 1 instância — ok em dev local, NÃO usar em produção).
#
# Como configurar: crie um banco Redis gratuito em https://upstash.com (ou via
# Vercel Marketplace → Upstash, que já injeta essas variáveis automaticamente)
# e copie os valores de "REST URL" e "REST TOKEN".
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
